---
import Layout from "@/layouts/Layout.astro";
---
<Layout title="Contact | Lanze">
  <section class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="flex flex-col items-center gap-8">

      <div class="text-center">
        <p class="text-2xl md:text-3xl opacity-50 font-mono mb-2">// Contact</p>
        <h1 class="text-4xl md:text-6xl font-bold">
          <span class="text-[#9b7ab8]">public static</span>
          <span class="text-[#eddcff]"> Contact </span>
          <span class="text-[#b76cff]">&#123;</span>
        </h1>
      </div>

      <p class="text-lg opacity-70">Feel free to reach out.</p>

      <div class="grid gap-4 w-full max-w-md">

        <a href="https://github.com/lnzem" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-4 border border-[#3b0060] rounded-lg px-6 py-4 bg-[#120018] hover:bg-[#1a0025] transition-colors group">
          <span class="text-[#9b7ab8] font-mono text-sm">01</span>
          <div class="flex flex-col text-left">
            <span class="text-xs font-mono opacity-40 mb-1">// github</span>
