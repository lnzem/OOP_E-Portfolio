            <span class="text-xs font-mono opacity-40 mb-1">// instagram</span>
            <span class="font-mono text-[#eddcff] group-hover:text-[#b76cff] transition-colors">@lnze.mtt</span>
          </div>
        </a>

        <a href="https://www.facebook.com/lanze.matthew.2024" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-4 border border-[#3b0060] rounded-lg px-6 py-4 bg-[#120018] hover:bg-[#1a0025] transition-colors group">
