            <span class="text-xs font-mono opacity-40 mb-1">// linkedin</span>
            <span class="font-mono text-[#eddcff] group-hover:text-[#b76cff] transition-colors">lanze-matthew-jallorina</span>
          </div>
        </a>

        <a href="https://www.instagram.com/lnze.mtt" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-4 border border-[#3b0060] rounded-lg px-6 py-4 bg-[#120018] hover:bg-[#1a0025] transition-colors group">
          <span class="text-[#9b7ab8] font-mono text-sm">03</span>
