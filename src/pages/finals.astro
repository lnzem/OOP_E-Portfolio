---
import Layout from "@/layouts/Layout.astro";
---
<Layout title="Finals | Lanze">
  <section class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="text-center flex flex-col items-center gap-6">
      <div class="mb-4">
        <p class="text-2xl md:text-3xl opacity-50 font-mono mb-2">// Finals</p>
        <h1 class="text-4xl md:text-6xl font-bold">
          <span class="text-[#9b7ab8]">private void</span>
          <span class="text-[#eddcff]"> Finals </span>
          <span class="text-[#b76cff]">&#123;</span>
        </h1>
      </div>
      <img
        src="/OOP_E-PORTFOLIO/undercons.png"
        alt="Under Construction"
        width="505"
        height="249"
        class="invert w-full max-w-[505px]"
      />
      <p class="text-xl opacity-70">Under construction. Check back soon.</p>
      <p class="text-[#b76cff] text-2xl font-bold">&#125;</p>
    </div>
  </section>
</Layout>