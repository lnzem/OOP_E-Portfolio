---
import Hero from "@/components/Hero.astro";
import Layout from "@/layouts/Layout.astro";
import { ABOUT_ME } from "@/consts";
---
<Layout title="Lanze Matthew | OOP E-Portfolio">
  <Hero />
<div class="w-full h-px bg-gradient-to-r from-transparent via-[#3b0060] to-transparent opacity-60"></div>
  <section
    id="introduction"
    class="min-h-screen px-4 py-24 w-screen !overflow-x-hidden flex items-center"
  >
    <div class="max-w-5xl mx-auto grid gap-10 intro-content px-4 md:px-16">

      <div class="grid gap-2">
        <p class="text-2xl md:text-4xl opacity-60 tracking-widest font-mono mb-2">// Introduction</p>
        <h2 class="text-3xl md:text-5xl font-bold">
          <span class="text-[#9b7ab8]">public class</span>
          <span class="text-[#eddcff]"> Lanze </span>
          <span class="text-[#b76cff]">&#123;</span>
        </h2>
      </div>
<div class="grid gap-4 pl-4 border-l border-[#3b0060]">
  <p class="text-lg opacity-80 leading-relaxed">{ABOUT_ME}</p>
  <p class="text-sm opacity-40 font-mono">
    <span class="text-[#9b7ab8]">String</span> section = <span class="text-[#b76cff]">"BSIT 2-1"</span>;
  </p>
</div>

      <div>
        <a
          href="/OOP_E-PORTFOLIO/midterm"
          class="inline-block border-2 border-white px-8 py-3 text-lg font-bold tracking-wider hover:bg-white hover:text-black transition-all ease-in-out"
        >
          &gt; View Midterm Outputs
        </a>
      </div>

      <div class="grid gap-2">
        <p class="text-[#b76cff] text-2xl font-bold">&#125;</p>
      </div>

      <div class="animate-bounce opacity-30 text-sm tracking-widest text-center">
        ↓ scroll
      </div>
    </div>
  </section>
</Layout>

<style>
  #introduction {
    background: linear-gradient(to bottom, transparent 0%, rgba(30, 0, 48, 0.3) 100%);
  }

  .intro-content {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .intro-content.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .intro-content.exit {
    opacity: 0;
    transform: translateY(-40px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
</style>

<script is:inline>
  const content = document.querySelector('.intro-content');
  if (content) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            content.classList.remove('exit');
            content.classList.add('visible');
          } else {
            const rect = content.getBoundingClientRect();
            if (rect.top < 0) {
              content.classList.add('exit');
            } else {
              content.classList.remove('visible');
              content.classList.remove('exit');
            }
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(content);
  }
</script>
