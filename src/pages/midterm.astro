const act2code = `// Part I - Bitwise Operators
public class BitwiseOperators {
    public static void main(String[] args) {
        int a = 5;   // binary: 0101
        int b = 10;  // binary: 01010
        int c = 13;  // binary: 01101

        System.out.println((a & c) > 0); // Bitwise AND (&): true
        System.out.println(b ^ 0);       // Bitwise XOR (^): 10
        System.out.println((~a) == a);   // Bitwise NOT (~): false
        a ^= b;
        System.out.println(a);           // XOR Assignment (^=): 15
    }
}

// Part I - Ternary Operator
public class TernaryOperators {
    public static void main(String[] args) {
        int a = 25;
        int b = 30;
        System.out.println(a < b ? true : false);
        System.out.println(a > b ? true : false);
        System.out.println(a < b ? a : b);
        System.out.println(a > b ? a : b);
    }
}

// Part I - Assignment Operators
public class AssignmentOperators {
    public static void main(String[] args) {
        int b = 24;
        int x;
        x = 96;  x += b; System.out.println("Addition: " + x);
        x = 94;  x -= b; System.out.println("Subtraction: " + x);
        x = 6;   x *= b; System.out.println("Multiplication: " + x);
        x = 384; x /= b; System.out.println("Division: " + x);
    }
}

// Part II - Mixed Operators
public class Operations {
    public static void main(String[] args) {
        int p = 7, q = 3, r = 15, s = 8, t = 20;
        System.out.println(p++ + ++p); // Unary (++): 16
        q *= r; System.out.println(q); // Assignment (*=): 45
        System.out.println(q > t);     // Relational (>): true
        System.out.println(!(s == q)); // Logical (!): true
        System.out.println(r ^ s);     // Bitwise (^): 7
        System.out.println(--t + t++); // Unary (--): 38
    }
}`;

const act3code = `import java.util.Scanner;

public class SimpleWalletJallorina {
    public static void main(String[] args) {
        int balance = 3000;
        int transactions = 0;
        System.out.println("===== Simple Wallet System =====");
        Scanner input = new Scanner(System.in);

        while (true) {
            System.out.println("===== WALLET MENU =====");
            System.out.println("1. View Balance");
            System.out.println("2. Add Money");
            System.out.println("3. Spend Money");
            System.out.println("4. Exit");
            System.out.print("Enter choice: ");
            int option = input.nextInt();

            switch (option) {
                case 1:
                    transactions++;
                    System.out.println("Balance: P" + balance);
                    break;
                case 2:
                    System.out.print("Enter amount of Money to add: P");
                    int addmoney = input.nextInt();
                    if (addmoney <= 0) {
                        System.out.println("Invalid Amount.");
                    } else {
                        balance += addmoney;
                        transactions++;
                        System.out.println("New Balance: P" + balance);
                    }
                    break;
                case 3:
                    System.out.print("Enter Amount you want to Spend: P");
                    int spend = input.nextInt();
                    if (spend <= 0) {
                        System.out.println("Invalid Amount!");
                    } else if (spend > 1000) {
                        System.out.println("Exceeds the maximum spend limit of 1000!");
                    } else if (spend > balance) {
                        System.out.println("Insufficient Balance!");
                    } else {
                        balance -= spend;
                        System.out.println("New Balance: P" + balance);
                        transactions++;
                    }
                    break;
                case 4:
                    System.out.println("Total Transactions: " + transactions);
                    System.out.println("Final Balance: P" + balance);
                    System.exit(0);
                    break;
                default:
                    System.out.println("Invalid choice. Try again.");
            }
        }
    }
}`;

const act4code = `public class GradeEvaluationJallorina {
    public static void main(String[] args) {
        double prelim = 85;
        double midterm = 78;
        double finals = 90;
        String remark;

        double average = (prelim + midterm + finals) / 3;

        if (average >= 90 && average <= 100) {
            remark = "Excellent";
        } else if (average >= 80 && average <= 89) {
            remark = "Good";
        } else if (average >= 75 && average <= 79) {
            remark = "Fair";
        } else {
            remark = "Failed";
        }

        System.out.println("Prelim Grade: " + prelim);
        System.out.println("Midterm Grade: " + midterm);
        System.out.println("Finals Grade: " + finals);
        System.out.printf("Average: %.2f%n", average);
        System.out.println("Remark: " + remark);
    }
}`;

const act5code = `import java.util.Scanner;

public class ExpenseTrackerJallorina {
    static void Titledisplay() {
        System.out.println("===== Personal Expense Tracker =====");
    }

    static double Calculatetotal(double food, double transportation, double other, double entertainment) {
        return food + transportation + other + entertainment;
    }

    static String Budgetcheck(double total, double budget) {
        if (total > budget) {
            double over = total - budget;
            return String.format("OVER BUDGET BY P %.2f!", over);
        } else if (total == budget) {
            return "You spent all your budget. Nothing left!";
        } else {
            return "You are within budget. Nice!";
        }
    }

    static void Summarydisplay(String name, double food, double transportation,
            double other, double entertainment, double total, double budget, String Budgetstatus) {
        double remaining = budget - total;
        System.out.println("===== Expense Summary =====");
        System.out.printf("Name           : %s%n", name);
        System.out.println("---------------");
        System.out.printf("Food           : P %.2f%n", food);
        System.out.printf("Transportation : P %.2f%n", transportation);
        System.out.printf("Entertainment  : P %.2f%n", entertainment);
        System.out.printf("Other          : P %.2f%n", other);
        System.out.println("----------");
        System.out.printf("Total Expenses : P %.2f%n", total);
        System.out.printf("Budget         : P %.2f%n", budget);
        System.out.println("----------");
        System.out.println("Status         : " + Budgetstatus);
        System.out.printf("Remaining      : P %.2f%n", remaining);
        System.out.println("====================");
        if (total > budget) {
            System.out.printf("%nHey %s, try to cut back on the spending! You might go homeless.%n", name);
        } else if (remaining >= budget * 0.5) {
            System.out.printf("%nWow %s, you're an amazing saver! Great work!%n", name);
        } else {
            System.out.printf("%nGood work, %s! Keep tracking!%n", name);
        }
        System.out.println("====================");
    }

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        Titledisplay();
        System.out.print("\\n Enter your name: ");
        String name = scan.nextLine();
        System.out.print(" Enter your budget (PESOS): ");
        double budget = scan.nextDouble();
        System.out.println("\\n Enter your expenses:");
        System.out.print(" Food           : P "); double food = scan.nextDouble();
        System.out.print(" Transportation : P "); double transportation = scan.nextDouble();
        System.out.print(" Entertainment  : P "); double entertainment = scan.nextDouble();
        System.out.print(" Other          : P "); double other = scan.nextDouble();
        double total = Calculatetotal(food, transportation, other, entertainment);
        String Budgetstatus = Budgetcheck(total, budget);
        Summarydisplay(name, food, transportation, other, entertainment, total, budget, Budgetstatus);
        scan.close();
    }
}`;
