---
import Layout from "@/layouts/Layout.astro";
---
<Layout title="Midterm | Lanze">
  <section class="min-h-screen px-4 py-28 max-w-4xl mx-auto">
    <h1 class="font-bold text-4xl md:text-6xl mb-10 text-center">&lt;Midterm /&gt;</h1>
    <div class="grid gap-8">
      <div id="quizzes" class="border-2 border-white rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">&gt; Quizzes</h2>
        <p class="opacity-70">Coming soon.</p>
      </div>
      <div id="seatworks" class="border-2 border-white rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">&gt; Seatworks</h2>
        <p class="opacity-70">Coming soon.</p>
      </div>
      <div id="activities" class="border-2 border-white rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">&gt; Activities</h2>
        <p class="opacity-70">Coming soon.</p>
      </div>
      <div id="exam" class="border-2 border-white rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">&gt; Exam</h2>
        <p class="opacity-70">Coming soon.</p>
      </div>
    </div>
  </section>
</Layout>
