const sw2code = `import java.util.Scanner;

public class ATMTransactionCounterJallorina {
    public static void main(String[] args) {
        int balance = 8000;
        int transactionsCounter = 0;
        boolean active = true;
        Scanner input = new Scanner(System.in);

        while (active) {
            System.out.println("===== ATM MENU =====");
            System.out.println("1. Check Balance");
            System.out.println("2. Deposit");
            System.out.println("3. Withdraw");
            System.out.println("4. Exit");
            System.out.print("Enter Choice: ");
            int option = input.nextInt();

            switch (option) {
                case 1:
                    transactionsCounter++;
                    System.out.println("Balance: P" + balance);
                    break;
                case 2:
                    System.out.print("Deposit amount: P");
                    int addbal = input.nextInt();
                    balance += addbal;
                    System.out.println("Deposited: P" + addbal);
                    System.out.println("New Balance: P" + balance);
                    break;
                case 3:
                    System.out.print("Withdraw amount: P");
                    int withdraw = input.nextInt();
                    transactionsCounter++;
                    if (withdraw > 2000) {
                        System.out.println("Exceeds maximum withdrawal of P2000!");
                    } else if (withdraw > balance) {
                        System.out.println("Insufficient balance!");
                    } else {
                        balance -= withdraw;
                        System.out.println("Withdrawn: P" + withdraw);
                        System.out.println("New Balance: P" + balance);
                    }
                    break;
                case 4:
                    System.out.println("Exiting.... Goodbye!");
                    active = false;
                    break;
                default:
                    System.out.println("Invalid choice. Try again.");
            }
        }

        System.out.println("Transaction Count: " + transactionsCounter);
        System.out.println("Final Balance: P" + balance);
    }
}`;

const sw3code = `import java.util.Scanner;

public class StudentAgeAnalyzerJallorina {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.println("=== Student Age Analyzer ===");

        System.out.print("Enter Student Name: ");
        String studentName = scanner.nextLine();
        System.out.print("Enter Student Age: ");
        int studentAge = scanner.nextInt();

        String category = ageCategorizer(studentAge);

        System.out.println("Name: " + studentName);
        System.out.println("Age: " + studentAge);
        System.out.println("Category: " + category);
    }

    public static String ageCategorizer(int studentAge) {
        if (studentAge >= 0 && studentAge <= 12) {
            return "Child";
        } else if (studentAge >= 13 && studentAge <= 19) {
            return "Teenager";
        } else if (studentAge >= 20 && studentAge <= 59) {
            return "Adult";
        } else if (studentAge >= 60) {
            return "Senior Citizen";
        } else {
            return "Invalid age!";
        }
    }
}`;

